const fs = require('fs')
const path = require('path')

const file = path.join(process.cwd(), 'app', 'page.tsx')
let content = fs.readFileSync(file, 'utf-8')

// Tim vi tri bat dau cua topup modal
const START = '{modal==="topup" ? ('
const END_MARKER = ') : ('

const startIdx = content.indexOf(START)
if (startIdx === -1) { console.error('Khong tim thay phan topup!'); process.exit(1) }

// Tim ) : ( tiep theo sau startIdx  
const endIdx = content.indexOf(END_MARKER, startIdx + START.length)
if (endIdx === -1) { console.error('Khong tim thay diem ket thuc!'); process.exit(1) }

// Noi dung moi (da ma hoa base64)
const newContent = Buffer.from('', 'base64').toString('utf-8')

// Ghep lai
const before = content.slice(0, startIdx)
const after  = content.slice(endIdx)
const result = before + START + '\n' + newContent + '\n              ' + after

// Backup file goc
fs.writeFileSync(file + '.bak', content, 'utf-8')
fs.writeFileSync(file, result, 'utf-8')

console.log('Cap nhat thanh cong!')
console.log('File goc backup tai: app/page.tsx.bak')